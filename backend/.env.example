# VaidyaAI Backend — Environment Variables
# Copy this file to .env for local development.
# In Cloud Run, set these via the GCP Console or --set-env-vars flag.
# NEVER commit .env to git.

# ── Server ──────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Vertex AI (Gemini) ───────────────────────────────────────────────
# Your GCP project ID (same project as Firebase)
VERTEX_AI_PROJECT_ID=vaidhya-ai

# Vertex AI region — us-central1 has the best Gemini model availability
VERTEX_AI_LOCATION=us-central1

# Gemini model to use for symptom triage
GEMINI_MODEL=gemini-2.5-pro

# ── Firebase Admin ───────────────────────────────────────────────────
# Local dev only: path to your downloaded service account JSON key.
# Download from: GCP Console -> IAM -> Service Accounts -> Keys -> Add Key -> JSON
# In Cloud Run: leave this EMPTY. Cloud Run uses Application Default Credentials.
# FIREBASE_ADMIN_CREDENTIAL=./serviceAccount.json

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Local dev: use your local dev server URL
# Production: set to your Firebase Hosting domain
ALLOWED_ORIGINS=http://localhost:3000

# ── Maps (served to authenticated clients via /config endpoint) ──────
# Get from: GCP Console -> APIs & Services -> Credentials
# Restrict to: Maps JavaScript API + HTTP referrers = https://YOUR-DOMAIN/*
# IMPORTANT: This key is served via the backend /config route after auth.
# It is NEVER included in frontend source files.
MAPS_API_KEY=
