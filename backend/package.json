{
  "name": "vaidyaai-backend",
  "version": "1.0.0",
  "description": "VaidyaAI Cloud Run backend — Gemini 2.5 Pro proxy, appointment booking, and slot management",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js --report-unused-disable-directives"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "middleware/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 60,
        "lines": 70,
        "functions": 70
      }
    }
  }
}
